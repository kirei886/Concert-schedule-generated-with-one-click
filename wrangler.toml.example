# Cloudflare Workers 配置模板
# 使用方法：复制为 wrangler.toml，填入你自己的值。
#   cp wrangler.toml.example wrangler.toml
# 注意：wrangler.toml 含密钥，不要提交到 Git（已在 .gitignore 中忽略建议）。

name = "concert-itinerary-api"
main = "src/worker-with-proxy.js"
compatibility_date = "2024-01-01"

# D1 数据库绑定（database_id 用你自己创建的 D1 实例 ID）
# 创建：wrangler d1 create concert-itinerary-db
[[d1_databases]]
binding = "DB"
database_name = "concert-itinerary-db"
database_id = "YOUR_D1_DATABASE_ID"

# 环境变量
# 生产环境推荐改用 `wrangler secret put JWT_SECRET` / `wrangler secret put LONGXIA_TOKEN`
# 而不是明文写在这里。
[vars]
JWT_SECRET = "change-this-to-a-strong-secret"
LONGXIA_TOKEN = "rdak_live_YOUR_LONGXIA_TOKEN"

[build]
command = ""
