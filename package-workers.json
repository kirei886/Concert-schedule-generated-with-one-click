{
  "name": "concert-itinerary-workers",
  "version": "2.1.0",
  "description": "演唱会行程生成器 - Cloudflare Workers 版本",
  "main": "src/worker.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "d1:create": "wrangler d1 create concert-itinerary-db",
    "d1:schema": "wrangler d1 execute concert-itinerary-db --file=./migrations/d1-schema.sql",
    "d1:seed": "wrangler d1 execute concert-itinerary-db --file=./migrations/d1-seed.sql",
    "d1:init": "npm run d1:schema && npm run d1:seed",
    "d1:query": "wrangler d1 execute concert-itinerary-db --command"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "concert",
    "itinerary"
  ],
  "author": "Claude Code",
  "license": "MIT",
  "dependencies": {
    "itty-router": "^4.0.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
